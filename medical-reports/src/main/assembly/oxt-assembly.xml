<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.1.1"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.1.1 http://maven.apache.org/xsd/assembly-2.1.1.xsd">
    <id>oxt</id>
    <formats>
        <format>zip</format>
    </formats>
    <includeBaseDirectory>false</includeBaseDirectory>

    <fileSets>
        <!-- META-INF directory -->
        <fileSet>
            <directory>${project.basedir}/META-INF</directory>
            <outputDirectory>META-INF</outputDirectory>
            <includes>
                <include>manifest.xml</include>
            </includes>
        </fileSet>

        <!-- Java classes and dependencies -->
        <fileSet>
            <directory>${project.build.directory}/classes</directory>
            <outputDirectory>classes</outputDirectory>
            <includes>
                <include>**/*.class</include>
            </includes>
        </fileSet>

        <!-- Library dependencies -->
        <fileSet>
            <directory>${project.build.directory}/classes/lib</directory>
            <outputDirectory>lib</outputDirectory>
            <includes>
                <include>*.jar</include>
            </includes>
        </fileSet>

        <!-- Resources -->
        <fileSet>
            <directory>${project.build.outputDirectory}</directory>
            <outputDirectory>.</outputDirectory>
            <includes>
                <include>**/*.properties</include>
            </includes>
        </fileSet>

        <!-- Templates -->
        <fileSet>
            <directory>${project.basedir}/src/main/templates</directory>
            <outputDirectory>templates</outputDirectory>
            <includes>
                <include>**/*.odt</include>
            </includes>
        </fileSet>

        <!-- UNO configuration files -->
        <fileSet>
            <directory>${project.basedir}/src/main/resources</directory>
            <outputDirectory>.</outputDirectory>
            <includes>
                <include>**/*.xcu</include>
            </includes>
        </fileSet>

        <!-- Main jar -->
        <fileSet>
            <directory>${project.build.directory}</directory>
            <outputDirectory>.</outputDirectory>
            <includes>
                <include>${project.artifactId}-${project.version}.jar</include>
            </includes>
        </fileSet>
    </fileSets>
</assembly>
